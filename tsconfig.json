{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "ES2023"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "module": "node16",
    "moduleResolution": "node16",
    "isolatedModules": true,
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
